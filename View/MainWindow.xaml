<Window x:Class="View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodel="clr-namespace:ViewModel;assembly=ViewModel"
        mc:Ignorable="d"
        Icon="logo.png"
        Title="Kuleczki" Height="500" Width="820">
    
    <Window.DataContext>
        <viewmodel:MainViewModel/>
    </Window.DataContext>

    <Border Padding="35">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="320"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ItemsControl Grid.Row="0" ItemsSource="{Binding Balls}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas Name="Canvas" Width="700" Height="300" Background="#363E6E"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding Position.X}"/>
                        <Setter Property="Canvas.Top" Value="{Binding Position.Y}"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Ellipse Height="{Binding Radius}" 
                                 Width="{Binding Radius}" 
                                 Fill="#6276F6"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button Content="START" 
                        Height="40" 
                        VerticalAlignment="Center" 
                        Margin="0,10,10,10" 
                        FontSize="15"
                        Padding="10"
                        FontWeight="Bold"
                        Background="#310dc4"
                        Foreground="White"
                        Command="{Binding StartSimulationCommand}">
                </Button>
    
                <StackPanel>
                    <TextBlock
                        Text="ILOŚĆ KULEK" 
                        FontWeight="Bold"
                        HorizontalAlignment="Center"
                        Margin="0,5,0,0"/>
                    <TextBox Width="100" 
                             Height="20"
                             Margin="0,5,0,0" 
                             Text="{Binding BallCount, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>